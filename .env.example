# ============================================================
# SentinelX AI-SOC — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=development            # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=sentinelx
DB_PASSWORD=sentinelx_secret
DB_NAME=sentinelx
DATABASE_URL=mysql+asyncmy://sentinelx:sentinelx_secret@mysql:3306/sentinelx

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ── Apache Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT     # SASL_SSL in production
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Kafka Topics
KAFKA_TOPIC_TELEMETRY=sentinelx.telemetry
KAFKA_TOPIC_EVENTS=sentinelx.events
KAFKA_TOPIC_ALERTS=sentinelx.alerts
KAFKA_TOPIC_RESPONSE=sentinelx.response
KAFKA_TOPIC_DLQ=sentinelx.dlq

# ── OpenSearch ───────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false              # true in production

# ── Authentication ──────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA
MFA_ISSUER=SentinelX

# OAuth2 (optional)
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=

# ── Threat Intelligence APIs ─────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=                          # AlienVault OTX
MISP_URL=
MISP_API_KEY=
NVD_API_KEY=                          # NIST NVD (optional, higher rate limits)

# ── AI / LLM ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=                    # Claude fallback
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=sentinelx-anomaly

# ── Observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=sentinelx
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin

# ── Agent ───────────────────────────────────────────────────
SENTINELX_API_URL=http://localhost:8001    # Telemetry service URL
SENTINELX_AGENT_TOKEN=                    # Set by registration flow
SENTINELX_HEARTBEAT_INTERVAL=60           # seconds

# ── AWS (Production) ─────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=sentinelx-artifacts
# AWS_EKS_CLUSTER=sentinelx-prod

# ── HashiCorp Vault (Production) ────────────────────────────
# VAULT_ADDR=
# VAULT_TOKEN=

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
