# Core Settings
API_KEY=default_dev_key
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# Application Config
RATE_LIMIT=100/minute
CACHE_REFRESH_INTERVAL=5
QUEUE_MAX_SIZE=10000
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Database
DATABASE_URL=sqlite:///data/firewall.db

# CORS Configuration
# Comma-separated list of allowed origins or "*"
CORS_ORIGINS='["*"]'

# Threat Intelligence
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
